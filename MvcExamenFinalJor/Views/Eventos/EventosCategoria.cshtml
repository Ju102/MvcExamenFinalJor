@model List<Evento>
@inject Microsoft.Extensions.Configuration.IConfiguration configuration
@{
    List<Categoria> categorias = ViewData["categorias"] as List<Categoria>;
    string bucketUrl = configuration.GetValue<string>("ConnectionStrings:BucketUrl");
}

<div class="container mt-4">
    <h2 class="mb-4 fw-bold text-primary">Catálogo de Eventos</h2>

    <div class="card shadow-sm mb-4 border-0 bg-light">
        <div class="card-body">
            <form method="post" class="row g-3 align-items-end">
                <div class="col-md-8 col-lg-6">
                    <label for="idcategoria" class="form-label fw-semibold text-secondary">Filtrar por categoría:</label>
                    <select name="idcategoria" id="idcategoria" class="form-select shadow-sm">
                        <option value="">Todas las categorías</option>
                        @if (categorias != null)
                        {
                            foreach (var categoria in categorias)
                            {
                                <option value="@categoria.IdCategoria">@categoria.Nombre</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-4 col-lg-3">
                    <button type="submit" class="btn btn-primary w-100 shadow-sm">
                        Filtrar Eventos
                    </button>
                </div>
            </form>
        </div>
    </div>

    @if (Model != null && Model.Count > 0)
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4">
            @foreach (Evento evento in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0">
                        <img src="@bucketUrl@evento.Imagen"
                             class="card-img-top"
                             style="height: 200px; object-fit: cover;"
                             alt="Imagen de @evento.Nombre" />

                        <div class="card-body">
                            <h5 class="card-title fw-bold text-truncate" title="@evento.Nombre">@evento.Nombre</h5>
                            <h6 class="card-subtitle mb-3 text-muted">@evento.Artista</h6>
                            <span class="badge bg-secondary">Categoría: @evento.IdCategoria</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info shadow-sm text-center py-4" role="alert">
            <h5 class="alert-heading">No se encontraron eventos</h5>
            <p class="mb-0">Prueba seleccionando otra categoría o verifica más tarde.</p>
        </div>
    }
</div>