@model List<Evento>
@inject Microsoft.Extensions.Configuration.IConfiguration configuration
@{
    string bucketUrl = configuration.GetValue<string>("ConnectionStrings:BucketUrl");
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary mb-0">Lista de Eventos</h2>
    </div>

    @if (Model != null && Model.Count > 0)
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4">
            @foreach (Evento evento in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0">
                        <img src="@bucketUrl@evento.Imagen"
                             class="card-img-top"
                             style="height: 200px; object-fit: cover;"
                             alt="Imagen de @evento.Nombre" />

                        <div class="card-body">
                            <h5 class="card-title fw-bold text-truncate" title="@evento.Nombre">
                                @evento.Nombre
                            </h5>
                            <h6 class="card-subtitle mb-3 text-muted">
                                <i class="bi bi-person"></i> @evento.Artista
                            </h6>

                            <span class="badge bg-secondary">Categoría: @evento.IdCategoria</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info shadow-sm text-center py-4" role="alert">
            <h4 class="alert-heading">¡Vaya!</h4>
            <p class="mb-0">No hay eventos disponibles en este momento.</p>
        </div>
    }
</div>